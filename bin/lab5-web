LAB5_JS = r"""
// Tiny vanilla JS — confirm before destructive triage actions.
(function(){
  document.querySelectorAll('form.triage-form').forEach(function(f){
    f.addEventListener('submit', function(e){
      var sel = f.querySelector('select[name="status"]');
      var status = sel && sel.value;
      var risky = (status === 'risk_accepted' || status === 'false_positive' || status === 'remediated');
      if (risky) {
        var ok = confirm('Record decision: ' + status.toUpperCase() + '?\n\nThis is append-only — prior decisions remain in audit trail.');
        if (!ok) { e.preventDefault(); }
      }
    });
  });
})();
"""


# ============================================================================
# ROUTING
# ============================================================================

class Lab5Handler(BaseHTTPRequestHandler):
    server_version = "lab5/1.0"
    sys_version = ""

    def log_message(self, fmt, *args):
        # Cleaner log line than the default
        sys.stderr.write("[%s] %s - %s\n" % (
            datetime.now().strftime("%H:%M:%S"),
            self.address_string(),
            fmt % args,
        ))

    def _send_html(self, status, body):
        b = body.encode('utf-8')
        self.send_response(status)
        self.send_header('Content-Type', 'text/html; charset=utf-8')
        self.send_header('Content-Length', str(len(b)))
        self.send_header('X-Frame-Options', 'DENY')
        self.send_header('X-Content-Type-Options', 'nosniff')
        self.end_headers()
        self.wfile.write(b)

    def _send_static(self, content_type, body):
        b = body.encode('utf-8')
        self.send_response(200)
        self.send_header('Content-Type', content_type + '; charset=utf-8')
        self.send_header('Content-Length', str(len(b)))
        self.send_header('Cache-Control', 'public, max-age=300')
        self.end_headers()
        self.wfile.write(b)

    def _redirect(self, location, status=303):
        self.send_response(status)
        self.send_header('Location', location)
        self.send_header('Content-Length', '0')
        self.end_headers()

    def do_GET(self):
        try:
            parsed = urllib.parse.urlparse(self.path)
            path = parsed.path
            query = urllib.parse.parse_qs(parsed.query)

            if path == '/static/lab5.css':
                self._send_static('text/css', LAB5_CSS); return
            if path == '/static/lab5.js':
                self._send_static('application/javascript', LAB5_JS); return

            if path == '/':
                self._send_html(200, page_dashboard()); return
            if path == '/findings':
                self._send_html(200, page_findings(query)); return
            if path == '/controls':
                self._send_html(200, page_controls()); return
            if path == '/scans':
                self._send_html(200, page_scans()); return

            m = re.match(r'^/findings/([^/]+)$', path)
            if m:
                body, status = page_finding_detail(urllib.parse.unquote(m.group(1)))
                self._send_html(status, body); return

            m = re.match(r'^/controls/([^/]+)$', path)
            if m:
                body, status = page_control_detail(urllib.parse.unquote(m.group(1)))
                self._send_html(status, body); return

            self._send_html(404, render_layout('Not found',
                '<section class="empty"><h1>404</h1><p>No such page.</p></section>'))
        except Exception as e:
            self.log_error("GET %s: %s", self.path, e)
            self._send_html(500, render_layout('Error',
                f'<section class="empty"><h1>500</h1><p>{esc(str(e))}</p></section>'))

    def do_POST(self):
        try:
            parsed = urllib.parse.urlparse(self.path)
            path = parsed.path

            m = re.match(r'^/findings/([^/]+)/triage$', path)
            if m:
                rhsa_id = urllib.parse.unquote(m.group(1))
                length = int(self.headers.get('Content-Length', '0'))
                body = self.rfile.read(length).decode('utf-8') if length else ''
                form = urllib.parse.parse_qs(body)
                status = (form.get('status', [''])[0] or '').strip()
                decided_by = (form.get('decided_by', [''])[0] or 'analyst').strip()
                notes = (form.get('notes', [''])[0] or '').strip()
                try:
                    insert_triage(rhsa_id, status, decided_by, notes)
                except ValueError as ve:
                    self._send_html(400, render_layout('Bad request',
                        f'<section class="empty"><h1>400</h1><p>{esc(str(ve))}</p></section>'))
                    return
                self._redirect(f'/findings/{urllib.parse.quote(rhsa_id)}')
                return

            self._send_html(405, render_layout('Not allowed',
                '<section class="empty"><h1>405</h1><p>Method not allowed.</p></section>'))
        except Exception as e:
            self.log_error("POST %s: %s", self.path, e)
            self._send_html(500, render_layout('Error',
                f'<section class="empty"><h1>500</h1><p>{esc(str(e))}</p></section>'))


# ============================================================================
# MAIN
# ============================================================================

def main():
    p = argparse.ArgumentParser(description="Lab 5 web UI")
    p.add_argument('--db', required=True, help='Path to lab5.db')
    p.add_argument('--host', default='127.0.0.1', help='Bind host (default 127.0.0.1)')
    p.add_argument('--port', type=int, default=5000, help='Bind port (default 5000)')
    args = p.parse_args()

    if not os.path.exists(args.db):
        print(f"ERROR: DB not found: {args.db}", file=sys.stderr)
        return 1

    global DB_PATH
    DB_PATH = os.path.abspath(args.db)

    server = HTTPServer((args.host, args.port), Lab5Handler)
    print(f"[*] Lab 5 web UI on http://{args.host}:{args.port}")
    print(f"[*] DB: {DB_PATH}")
    print(f"[*] SSH tunnel from workstation:")
    print(f"        ssh -L {args.port}:127.0.0.1:{args.port} <user>@<vm-host>")
    print(f"[*] Then open http://localhost:{args.port} in your browser")
    print(f"[*] Ctrl+C to stop")
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\n[*] Shutting down...")
        server.server_close()
    return 0


if __name__ == '__main__':
    sys.exit(main())
