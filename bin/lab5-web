#!/usr/bin/env python3
"""
lab5-web: Single-file stdlib HTTP server for browsing the Lab 5 vuln database.

Lab 5 — ACAS-Equivalent Vulnerability Management Pipeline
System:  RHEL 9.6 (Plow), Python 3.9, stdlib only
Author:  Elijah Beese

Usage:
    bin/lab5-web --db /home/<user>/lab5/db/lab5.db [--port 5000] [--host 127.0.0.1]

Default binds to 127.0.0.1:5000. Access from your workstation via SSH tunnel:
    ssh -L 5000:127.0.0.1:5000 <user>@<your-vm-host>
Then point a browser at http://localhost:5000

Design notes:
    * Zero pip dependencies. Pure Python 3 stdlib (http.server, sqlite3,
      urllib, html, string.Template). Defensible for airgapped environments.
    * Server-rendered HTML. No JS framework. No build step. No CDN.
    * Minimal vanilla JS for severity filter pills and CVE collapsibles.
    * Aesthetic: terminal-grade SOC console — dark, monospaced, dense.
    * Read-mostly. Only the /findings/<rhsa>/triage POST handler writes,
      and it only INSERTs append-only triage rows (it never UPDATEs).
    * No CSRF protection in v1: single-user, localhost-bound, behind SSH
      tunnel. Threat model doesn't require it. Document this if scope grows.

Routes:
    GET   /                              dashboard
    GET   /findings                      findings list (?severity= &status= &package= filters)
    GET   /findings/<rhsa_id>            finding detail + triage history
    POST  /findings/<rhsa_id>/triage     submit a triage decision
    GET   /controls                      controls pivot (mappings per control)
    GET   /controls/<control_id>         control detail (RHSAs mapped to it)
    GET   /scans                         scan history
    GET   /static/lab5.css               stylesheet
    GET   /static/lab5.js                vanilla JS
"""

import argparse
import html
import json
import os
import re
import sqlite3
import string
import sys
import urllib.parse
from datetime import datetime, timezone
from http.server import BaseHTTPRequestHandler, HTTPServer


# ============================================================================
# CONSTANTS
# ============================================================================

VALID_TRIAGE_STATUSES = {
    'open', 'in_progress', 'mitigated', 'risk_accepted',
    'false_positive', 'remediated',
}

SEVERITY_ORDER = {'Critical': 0, 'Important': 1, 'Moderate': 2, 'Low': 3, 'Unknown': 4}


# ============================================================================
# DB HELPERS
# ============================================================================

DB_PATH = None  # set by main()

def db():
    """Open a connection. SQLite is fine being opened per-request for our scale."""
    conn = sqlite3.connect(DB_PATH)
    conn.row_factory = sqlite3.Row
    conn.execute("PRAGMA foreign_keys = ON")
    return conn


def latest_scan_id():
    with db() as c:
        row = c.execute("SELECT scan_id FROM scans ORDER BY scan_date DESC LIMIT 1").fetchone()
        return row['scan_id'] if row else None


def latest_scan_info():
    with db() as c:
        return c.execute("SELECT * FROM scans ORDER BY scan_date DESC LIMIT 1").fetchone()


def severity_summary():
    """Counts open findings per severity in the latest scan, ignoring resolved."""
    sid = latest_scan_id()
    if sid is None:
        return []
    with db() as c:
        rows = c.execute("""
            SELECT v.severity, COUNT(*) as count
            FROM findings f
            JOIN vulnerabilities v ON f.rhsa_id = v.rhsa_id
            LEFT JOIN (
                SELECT rhsa_id, status FROM triage_decisions WHERE superseded = 0
            ) t ON v.rhsa_id = t.rhsa_id
            WHERE f.scan_id = ?
              AND COALESCE(t.status, 'open') NOT IN ('remediated', 'risk_accepted', 'false_positive')
            GROUP BY v.severity
        """, (sid,)).fetchall()
    return sorted(rows, key=lambda r: SEVERITY_ORDER.get(r['severity'], 99))


def triage_summary():
    """Counts of all triage statuses across the current scan's findings."""
    sid = latest_scan_id()
    if sid is None:
        return []
    with db() as c:
        rows = c.execute("""
            SELECT COALESCE(t.status, 'open') as status, COUNT(*) as count
            FROM findings f
            JOIN vulnerabilities v ON f.rhsa_id = v.rhsa_id
            LEFT JOIN (
                SELECT rhsa_id, status FROM triage_decisions WHERE superseded = 0
            ) t ON v.rhsa_id = t.rhsa_id
            WHERE f.scan_id = ?
            GROUP BY COALESCE(t.status, 'open')
            ORDER BY 2 DESC
        """, (sid,)).fetchall()
    return rows


def package_summary():
    sid = latest_scan_id()
    if sid is None:
        return []
    with db() as c:
        return c.execute("""
            SELECT v.package_name, COUNT(*) as count
            FROM findings f
            JOIN vulnerabilities v ON f.rhsa_id = v.rhsa_id
            WHERE f.scan_id = ? AND v.package_name IS NOT NULL
            GROUP BY v.package_name
            ORDER BY count DESC, v.package_name
            LIMIT 12
        """, (sid,)).fetchall()


def control_family_summary():
    """Count of (RHSA, control) mapping pairs grouped by control family."""
    with db() as c:
        return c.execute("""
            SELECT c.family, COUNT(DISTINCT m.rhsa_id || '|' || m.control_id) as mappings
            FROM vuln_control_mappings m
            JOIN controls_800_53 c ON m.control_id = c.control_id
            GROUP BY c.family
            ORDER BY mappings DESC
        """).fetchall()


def all_findings(severity=None, status=None, package=None, sort='severity'):
    """Latest-scan findings, with current triage status, optionally filtered."""
    sid = latest_scan_id()
    if sid is None:
        return []
    sql = """
        SELECT v.rhsa_id, v.title, v.severity, v.package_name,
               COALESCE(t.status, 'open') as current_status,
               (SELECT COUNT(*) FROM vulnerability_cves WHERE rhsa_id = v.rhsa_id) as cve_count
        FROM findings f
        JOIN vulnerabilities v ON f.rhsa_id = v.rhsa_id
        LEFT JOIN (
            SELECT rhsa_id, status FROM triage_decisions WHERE superseded = 0
        ) t ON v.rhsa_id = t.rhsa_id
        WHERE f.scan_id = ?
    """
    params = [sid]
    if severity:
        sql += " AND v.severity = ?"
        params.append(severity)
    if status:
        sql += " AND COALESCE(t.status, 'open') = ?"
        params.append(status)
    if package:
        sql += " AND v.package_name = ?"
        params.append(package)

    if sort == 'package':
        sql += " ORDER BY v.package_name, v.severity"
    elif sort == 'rhsa':
        sql += " ORDER BY v.rhsa_id"
    else:  # severity
        sql += """ ORDER BY
            CASE v.severity
                WHEN 'Critical' THEN 0 WHEN 'Important' THEN 1
                WHEN 'Moderate' THEN 2 WHEN 'Low' THEN 3 ELSE 4 END,
            v.rhsa_id
        """

    with db() as c:
        return c.execute(sql, params).fetchall()


def finding_detail(rhsa_id):
    with db() as c:
        vuln = c.execute("""
            SELECT v.*, s_first.scan_date as first_seen_date, s_last.scan_date as last_seen_date
            FROM vulnerabilities v
            LEFT JOIN scans s_first ON v.first_seen_scan_id = s_first.scan_id
            LEFT JOIN scans s_last ON v.last_seen_scan_id = s_last.scan_id
            WHERE v.rhsa_id = ?
        """, (rhsa_id,)).fetchone()
        if not vuln:
            return None
        cves = [r['cve_id'] for r in c.execute(
            "SELECT cve_id FROM vulnerability_cves WHERE rhsa_id = ? ORDER BY cve_id",
            (rhsa_id,)).fetchall()]
        controls = c.execute("""
            SELECT m.control_id, c.title, m.confidence
            FROM vuln_control_mappings m
            JOIN controls_800_53 c ON m.control_id = c.control_id
            WHERE m.rhsa_id = ?
            ORDER BY m.control_id
        """, (rhsa_id,)).fetchall()
        triage_history = c.execute("""
            SELECT * FROM triage_decisions WHERE rhsa_id = ?
            ORDER BY decided_at DESC
        """, (rhsa_id,)).fetchall()
        current = None
        for t in triage_history:
            if t['superseded'] == 0:
                current = t
                break
    return {
        'vuln': vuln,
        'cves': cves,
        'controls': controls,
        'triage_history': triage_history,
        'current_triage': current,
    }


def insert_triage(rhsa_id, status, decided_by, notes):
    """Append-only triage. Mark all prior rows for this RHSA as superseded,
    then insert the new one."""
    if status not in VALID_TRIAGE_STATUSES:
        raise ValueError(f"invalid status: {status}")
    now = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    with db() as c:
        c.execute("UPDATE triage_decisions SET superseded = 1 WHERE rhsa_id = ?", (rhsa_id,))
        c.execute("""
            INSERT INTO triage_decisions (rhsa_id, status, decided_at, decided_by, notes, superseded)
            VALUES (?, ?, ?, ?, ?, 0)
        """, (rhsa_id, status, now, decided_by or 'analyst', notes or None))
        c.commit()


def all_controls_with_mappings():
    """List of controls that have at least one mapping, with counts."""
    with db() as c:
        return c.execute("""
            SELECT m.control_id, c.title, c.family, c.baseline,
                   COUNT(DISTINCT m.rhsa_id) as vuln_count
            FROM vuln_control_mappings m
            JOIN controls_800_53 c ON m.control_id = c.control_id
            GROUP BY m.control_id
            ORDER BY vuln_count DESC, m.control_id
        """).fetchall()


def control_detail(control_id):
    with db() as c:
        ctrl = c.execute("SELECT * FROM controls_800_53 WHERE control_id = ?",
                         (control_id,)).fetchone()
        if not ctrl:
            return None
        rhsas = c.execute("""
            SELECT v.rhsa_id, v.title, v.severity, v.package_name, m.confidence
            FROM vuln_control_mappings m
            JOIN vulnerabilities v ON m.rhsa_id = v.rhsa_id
            WHERE m.control_id = ?
            ORDER BY
                CASE v.severity WHEN 'Critical' THEN 0 WHEN 'Important' THEN 1
                                WHEN 'Moderate' THEN 2 WHEN 'Low' THEN 3 ELSE 4 END,
                v.rhsa_id
        """, (control_id,)).fetchall()
    return {'control': ctrl, 'rhsas': rhsas}


def all_scans():
    with db() as c:
        return c.execute("""
            SELECT s.*,
                   (SELECT COUNT(*) FROM findings WHERE scan_id = s.scan_id) as finding_count
            FROM scans s
            ORDER BY s.scan_date DESC
        """).fetchall()


# ============================================================================
# RENDERING — string.Template + small helpers, no Jinja2
# ============================================================================

def esc(s):
    """HTML-escape, return empty string for None."""
    return html.escape('' if s is None else str(s))


def severity_class(sev):
    return {
        'Critical': 'sev-critical', 'Important': 'sev-important',
        'Moderate': 'sev-moderate', 'Low': 'sev-low',
    }.get(sev, 'sev-unknown')


def status_class(st):
    return {
        'open': 'st-open', 'in_progress': 'st-progress',
        'mitigated': 'st-mitigated', 'risk_accepted': 'st-accepted',
        'false_positive': 'st-fp', 'remediated': 'st-remediated',
    }.get(st, 'st-open')


def status_label(st):
    return {
        'open': 'OPEN', 'in_progress': 'IN PROGRESS',
        'mitigated': 'MITIGATED', 'risk_accepted': 'RISK ACCEPTED',
        'false_positive': 'FALSE POSITIVE', 'remediated': 'REMEDIATED',
    }.get(st, st.upper())


# Strip 'RHSA-2025:9978: ' prefix from titles for cleaner display.
# Defined as a function (not inline regex in f-strings) because Python 3.9
# rejects backslashes inside f-string expressions.
_RHSA_PREFIX_RE = re.compile(r'^RHSA-\d+:\d+:\s*')

def strip_rhsa_prefix(s):
    return _RHSA_PREFIX_RE.sub('', s) if s else ''


# Single layout shell. All pages plug into ${content}.
LAYOUT = string.Template("""<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>${title} — Lab 5 Console</title>
<link rel="stylesheet" href="/static/lab5.css">
</head>
<body>
<header class="topbar">
  <div class="brand">
    <span class="brand-mark">[L5]</span>
    <span class="brand-name">VULN MANAGEMENT CONSOLE</span>
  </div>
  <nav class="nav">
    <a href="/"          class="nav-item ${nav_dash}">DASHBOARD</a>
    <a href="/findings"  class="nav-item ${nav_find}">FINDINGS</a>
    <a href="/controls"  class="nav-item ${nav_ctrl}">CONTROLS</a>
    <a href="/scans"     class="nav-item ${nav_scan}">SCANS</a>
  </nav>
  <div class="meta">
    <span class="meta-label">SCAN</span>
    <span class="meta-value">${scan_meta}</span>
  </div>
</header>
<main class="main">${content}</main>
<footer class="bottom">
  lab5 • single-user offline build • <span class="muted">${scan_host}</span>
</footer>
<script src="/static/lab5.js"></script>
</body>
</html>""")


def render_layout(title, content, active_nav='', scan_info=None):
    if scan_info is None:
        scan_info = latest_scan_info()
    if scan_info:
        try:
            fp = json.loads(scan_info['system_fingerprint'])
            host = fp.get('primary_host_name', 'unknown')
        except Exception:
            host = 'unknown'
        scan_meta = f"{esc(scan_info['scan_date'])} • {esc(scan_info['feed_file'])} • {scan_info['true_count']} findings"
    else:
        scan_meta = "no scans imported yet"
        host = 'unknown'

    return LAYOUT.substitute(
        title=esc(title),
        content=content,
        scan_meta=scan_meta,
        scan_host=esc(host),
        nav_dash='active' if active_nav == 'dash' else '',
        nav_find='active' if active_nav == 'find' else '',
        nav_ctrl='active' if active_nav == 'ctrl' else '',
        nav_scan='active' if active_nav == 'scan' else '',
    )


# ----------------------------------------------------------------------------
# Page: dashboard
# ----------------------------------------------------------------------------

def page_dashboard():
    sev = severity_summary()
    tri = triage_summary()
    pkg = package_summary()
    fam = control_family_summary()
    scan = latest_scan_info()

    if scan is None:
        body = """<section class="empty">
          <h1>NO SCANS IMPORTED</h1>
          <p>Run <code>bin/acas-import</code> to ingest an OpenSCAP results XML.</p>
        </section>"""
        return render_layout('Dashboard', body, 'dash')

    # Severity tiles
    sev_total = sum(r['count'] for r in sev)
    sev_tiles = []
    for s in ['Critical', 'Important', 'Moderate', 'Low']:
        count = next((r['count'] for r in sev if r['severity'] == s), 0)
        sev_tiles.append(f"""
          <a class="tile {severity_class(s)}" href="/findings?severity={esc(s)}">
            <div class="tile-count">{count}</div>
            <div class="tile-label">{esc(s).upper()}</div>
          </a>
        """)
    sev_html = '\n'.join(sev_tiles)

    # Triage breakdown
    tri_rows = []
    for r in tri:
        tri_rows.append(f"""
          <tr>
            <td><span class="status-pill {status_class(r['status'])}">{esc(status_label(r['status']))}</span></td>
            <td class="num">{r['count']}</td>
          </tr>
        """)
    tri_html = '\n'.join(tri_rows) if tri_rows else '<tr><td colspan="2" class="muted">no findings</td></tr>'

    # Top packages
    pkg_rows = []
    for r in pkg:
        pkg_rows.append(f"""
          <tr>
            <td><a href="/findings?package={esc(r['package_name'])}">{esc(r['package_name'])}</a></td>
            <td class="num">{r['count']}</td>
          </tr>
        """)
    pkg_html = '\n'.join(pkg_rows) if pkg_rows else '<tr><td colspan="2" class="muted">no data</td></tr>'

    # Control family bars
    max_fam = max((r['mappings'] for r in fam), default=1)
    fam_rows = []
    for r in fam:
        pct = int((r['mappings'] / max_fam) * 100) if max_fam else 0
        fam_rows.append(f"""
          <tr>
            <td class="fam-cell">{esc(r['family'])}</td>
            <td><div class="bar"><div class="bar-fill" style="width: {pct}%"></div></div></td>
            <td class="num">{r['mappings']}</td>
          </tr>
        """)
    fam_html = '\n'.join(fam_rows) if fam_rows else '<tr><td colspan="3" class="muted">no mappings</td></tr>'

    # System fingerprint
    try:
        fp = json.loads(scan['system_fingerprint'])
    except Exception:
        fp = {}

    body = f"""
    <section class="hero">
      <div class="hero-numbers">
        <div class="hero-stat">
          <div class="hero-num">{sev_total}</div>
          <div class="hero-label">OPEN FINDINGS</div>
        </div>
        <div class="hero-divider"></div>
        <div class="hero-meta">
          <div class="hero-line"><span class="key">HOST</span> <span class="val">{esc(fp.get('primary_host_name','—'))}</span></div>
          <div class="hero-line"><span class="key">OS</span> <span class="val">{esc(fp.get('os_name','—'))} {esc(fp.get('os_version',''))}</span></div>
          <div class="hero-line"><span class="key">ARCH</span> <span class="val">{esc(fp.get('architecture','—'))}</span></div>
          <div class="hero-line"><span class="key">FEED</span> <span class="val">{esc(scan['feed_file'])}</span></div>
          <div class="hero-line"><span class="key">SCAN</span> <span class="val">{esc(scan['scan_date'])}</span></div>
          <div class="hero-line"><span class="key">SHA-256</span> <span class="val mono-tiny">{esc(scan['feed_sha256'])}</span></div>
        </div>
      </div>
    </section>

    <section class="tiles">
      {sev_html}
    </section>

    <section class="grid-3">
      <div class="panel">
        <h2 class="panel-h">TRIAGE STATUS</h2>
        <table class="tbl">
          <thead><tr><th>STATUS</th><th class="num">COUNT</th></tr></thead>
          <tbody>{tri_html}</tbody>
        </table>
      </div>
      <div class="panel">
        <h2 class="panel-h">TOP AFFECTED PACKAGES</h2>
        <table class="tbl">
          <thead><tr><th>PACKAGE</th><th class="num">RHSAs</th></tr></thead>
          <tbody>{pkg_html}</tbody>
        </table>
      </div>
      <div class="panel">
        <h2 class="panel-h">CONTROL FAMILY MAPPINGS</h2>
        <table class="tbl">
          <thead><tr><th>FAMILY</th><th>DENSITY</th><th class="num">COUNT</th></tr></thead>
          <tbody>{fam_html}</tbody>
        </table>
      </div>
    </section>
    """
    return render_layout('Dashboard', body, 'dash', scan)


# ----------------------------------------------------------------------------
# Page: findings list
# ----------------------------------------------------------------------------

def page_findings(query):
    severity = query.get('severity', [None])[0]
    status   = query.get('status',   [None])[0]
    package  = query.get('package',  [None])[0]
    sort     = query.get('sort',     ['severity'])[0]

    findings = all_findings(severity=severity, status=status, package=package, sort=sort)

    # Filter pill bar — built from current state
    def pill(label, key, value, current):
        active = ' active' if current == value else ''
        if value is None:
            href = '/findings'
            params = {k:v for k,v in [('severity',severity),('status',status),('package',package)] if v and k != key}
        else:
            params = {k:v for k,v in [('severity',severity),('status',status),('package',package)] if v}
            params[key] = value
            href = '/findings?' + urllib.parse.urlencode(params) if params else '/findings'
        return f'<a class="pill{active}" href="{esc(href)}">{esc(label)}</a>'

    sev_pills = (
        pill('ALL', 'severity', None, severity) +
        pill('CRITICAL',  'severity', 'Critical',  severity) +
        pill('IMPORTANT', 'severity', 'Important', severity) +
        pill('MODERATE',  'severity', 'Moderate',  severity) +
        pill('LOW',       'severity', 'Low',       severity)
    )
    status_pills = (
        pill('ALL STATUS',  'status', None,             status) +
        pill('OPEN',        'status', 'open',           status) +
        pill('IN PROGRESS', 'status', 'in_progress',    status) +
        pill('MITIGATED',   'status', 'mitigated',      status) +
        pill('ACCEPTED',    'status', 'risk_accepted',  status) +
        pill('FALSE POS.',  'status', 'false_positive', status) +
        pill('REMEDIATED',  'status', 'remediated',     status)
    )

    rows = []
    for r in findings:
        rows.append(f"""
          <tr class="row-{severity_class(r['severity'])}">
            <td><span class="sev-tag {severity_class(r['severity'])}">{esc(r['severity']).upper()}</span></td>
            <td class="mono"><a href="/findings/{esc(r['rhsa_id'])}">{esc(r['rhsa_id'])}</a></td>
            <td>{esc(r['package_name'] or '—')}</td>
            <td class="num">{r['cve_count']}</td>
            <td><span class="status-pill {status_class(r['current_status'])}">{esc(status_label(r['current_status']))}</span></td>
            <td class="title-cell">{esc(strip_rhsa_prefix(r['title']))}</td>
          </tr>
        """)
    rows_html = '\n'.join(rows) if rows else '<tr><td colspan="6" class="muted">no findings match these filters</td></tr>'

    # Active filter chip
    chip_parts = []
    if severity: chip_parts.append(f'severity = <strong>{esc(severity)}</strong>')
    if status:   chip_parts.append(f'status = <strong>{esc(status_label(status))}</strong>')
    if package:  chip_parts.append(f'package = <strong>{esc(package)}</strong>')
    chip_html = ' • '.join(chip_parts) if chip_parts else '<span class="muted">no filters</span>'

    body = f"""
    <section class="page-h">
      <h1 class="h-page">FINDINGS</h1>
      <div class="page-h-meta">{len(findings)} matching • {chip_html}</div>
    </section>
    <section class="filters">
      <div class="filter-group"><span class="filter-lbl">SEVERITY</span>{sev_pills}</div>
      <div class="filter-group"><span class="filter-lbl">STATUS</span>{status_pills}</div>
    </section>
    <section class="panel panel-flush">
      <table class="tbl tbl-findings">
        <thead><tr>
          <th>SEV</th><th>RHSA</th><th>PACKAGE</th><th class="num">CVEs</th>
          <th>TRIAGE</th><th>TITLE</th>
        </tr></thead>
        <tbody>{rows_html}</tbody>
      </table>
    </section>
    """
    return render_layout('Findings', body, 'find')


# ----------------------------------------------------------------------------
# Page: finding detail
# ----------------------------------------------------------------------------

def page_finding_detail(rhsa_id):
    d = finding_detail(rhsa_id)
    if d is None:
        return render_layout('Not found',
            f'<section class="empty"><h1>404</h1><p>RHSA <code>{esc(rhsa_id)}</code> not found.</p></section>',
            'find'), 404

    v = d['vuln']
    cur = d['current_triage']
    cur_status = cur['status'] if cur else 'open'

    # CVE list
    cve_html = ''.join(f'<li class="mono">{esc(c)}</li>' for c in d['cves']) \
        or '<li class="muted">none</li>'

    # Controls table
    ctrl_rows = []
    for r in d['controls']:
        ctrl_rows.append(f"""
          <tr>
            <td class="mono"><a href="/controls/{esc(r['control_id'])}">{esc(r['control_id'])}</a></td>
            <td>{esc(r['title'])}</td>
            <td><span class="conf conf-{esc(r['confidence'])}">{esc(r['confidence'])}</span></td>
          </tr>
        """)
    ctrl_html = '\n'.join(ctrl_rows) if ctrl_rows else '<tr><td colspan="3" class="muted">no mappings</td></tr>'

    # Triage history
    hist_rows = []
    for t in d['triage_history']:
        marker = '◆' if t['superseded'] == 0 else '·'
        hist_rows.append(f"""
          <tr class="{'current' if t['superseded'] == 0 else 'historical'}">
            <td class="mono-tiny">{marker} {esc(t['decided_at'])}</td>
            <td><span class="status-pill {status_class(t['status'])}">{esc(status_label(t['status']))}</span></td>
            <td>{esc(t['decided_by'])}</td>
            <td class="notes-cell">{esc(t['notes'] or '')}</td>
          </tr>
        """)
    hist_html = '\n'.join(hist_rows) if hist_rows else '<tr><td colspan="4" class="muted">no triage decisions yet</td></tr>'

    title_clean = strip_rhsa_prefix(v['title'])

    body = f"""
    <section class="page-h">
      <a class="backlink" href="/findings">← findings</a>
      <h1 class="h-page mono">{esc(v['rhsa_id'])}</h1>
      <div class="subtitle">{esc(title_clean)}</div>
    </section>

    <section class="grid-2">
      <div class="panel">
        <h2 class="panel-h">VULNERABILITY</h2>
        <dl class="kv">
          <dt>Severity</dt>
          <dd><span class="sev-tag {severity_class(v['severity'])}">{esc(v['severity']).upper()}</span></dd>
          <dt>Package</dt><dd class="mono">{esc(v['package_name'] or '—')}</dd>
          <dt>Class</dt><dd class="mono">{esc(v['class'])}</dd>
          <dt>OVAL definition</dt><dd class="mono mono-tiny">{esc(v['definition_id'])}</dd>
          <dt>First seen</dt><dd class="mono">{esc(v['first_seen_date'] or '—')}</dd>
          <dt>Last seen</dt><dd class="mono">{esc(v['last_seen_date'] or '—')}</dd>
        </dl>
      </div>
      <div class="panel">
        <h2 class="panel-h">CVEs <span class="counter">{len(d['cves'])}</span></h2>
        <ul class="cve-list">{cve_html}</ul>
      </div>
    </section>

    <section class="panel">
      <h2 class="panel-h">MAPPED 800-53 CONTROLS <span class="counter">{len(d['controls'])}</span></h2>
      <table class="tbl">
        <thead><tr><th>CONTROL</th><th>TITLE</th><th>CONFIDENCE</th></tr></thead>
        <tbody>{ctrl_html}</tbody>
      </table>
    </section>

    <section class="grid-2">
      <div class="panel">
        <h2 class="panel-h">TRIAGE — RECORD DECISION</h2>
        <form class="triage-form" method="POST" action="/findings/{esc(v['rhsa_id'])}/triage">
          <label>STATUS
            <select name="status" required>
              <option value="open"           {'selected' if cur_status=='open' else ''}>Open</option>
              <option value="in_progress"    {'selected' if cur_status=='in_progress' else ''}>In progress</option>
              <option value="mitigated"      {'selected' if cur_status=='mitigated' else ''}>Mitigated</option>
              <option value="risk_accepted"  {'selected' if cur_status=='risk_accepted' else ''}>Risk accepted</option>
              <option value="false_positive" {'selected' if cur_status=='false_positive' else ''}>False positive</option>
              <option value="remediated"     {'selected' if cur_status=='remediated' else ''}>Remediated</option>
            </select>
          </label>
          <label>DECIDED BY
            <input name="decided_by" type="text" value="analyst" required>
          </label>
          <label>NOTES
            <textarea name="notes" rows="3" placeholder="rationale, compensating controls, milestone date..."></textarea>
          </label>
          <button type="submit" class="btn">RECORD DECISION</button>
        </form>
      </div>
      <div class="panel">
        <h2 class="panel-h">TRIAGE HISTORY <span class="counter">{len(d['triage_history'])}</span></h2>
        <table class="tbl tbl-triage">
          <thead><tr><th>WHEN</th><th>STATUS</th><th>BY</th><th>NOTES</th></tr></thead>
          <tbody>{hist_html}</tbody>
        </table>
      </div>
    </section>
    """
    return render_layout(v['rhsa_id'], body, 'find'), 200


# ----------------------------------------------------------------------------
# Page: controls list
# ----------------------------------------------------------------------------

def page_controls():
    rows = all_controls_with_mappings()
    max_count = max((r['vuln_count'] for r in rows), default=1)

    tbody = []
    for r in rows:
        pct = int((r['vuln_count'] / max_count) * 100) if max_count else 0
        bl = r['baseline'] or 'None'
        tbody.append(f"""
          <tr>
            <td class="mono"><a href="/controls/{esc(r['control_id'])}">{esc(r['control_id'])}</a></td>
            <td>{esc(r['family'])}</td>
            <td>{esc(r['title'])}</td>
            <td><span class="bl bl-{esc(bl).lower()}">{esc(bl).upper()}</span></td>
            <td><div class="bar"><div class="bar-fill" style="width: {pct}%"></div></div></td>
            <td class="num">{r['vuln_count']}</td>
          </tr>
        """)
    body_html = '\n'.join(tbody) if tbody else '<tr><td colspan="6" class="muted">no mappings</td></tr>'

    body = f"""
    <section class="page-h">
      <h1 class="h-page">CONTROL MAPPINGS</h1>
      <div class="page-h-meta">{len(rows)} controls with one or more mapped RHSAs</div>
    </section>
    <section class="panel panel-flush">
      <table class="tbl tbl-controls">
        <thead><tr>
          <th>CONTROL</th><th>FAMILY</th><th>TITLE</th>
          <th>BASELINE</th><th>DENSITY</th><th class="num">RHSAs</th>
        </tr></thead>
        <tbody>{body_html}</tbody>
      </table>
    </section>
    """
    return render_layout('Controls', body, 'ctrl')


# ----------------------------------------------------------------------------
# Page: control detail
# ----------------------------------------------------------------------------

def page_control_detail(control_id):
    d = control_detail(control_id)
    if d is None:
        return render_layout('Not found',
            f'<section class="empty"><h1>404</h1><p>Control <code>{esc(control_id)}</code> not found.</p></section>',
            'ctrl'), 404

    c = d['control']
    rows = []
    for r in d['rhsas']:
        rows.append(f"""
          <tr>
            <td><span class="sev-tag {severity_class(r['severity'])}">{esc(r['severity']).upper()}</span></td>
            <td class="mono"><a href="/findings/{esc(r['rhsa_id'])}">{esc(r['rhsa_id'])}</a></td>
            <td>{esc(r['package_name'] or '—')}</td>
            <td><span class="conf conf-{esc(r['confidence'])}">{esc(r['confidence'])}</span></td>
            <td class="title-cell">{esc(strip_rhsa_prefix(r['title']))}</td>
          </tr>
        """)
    rows_html = '\n'.join(rows) if rows else '<tr><td colspan="5" class="muted">no RHSAs mapped to this control</td></tr>'

    desc_short = (c['description'] or '')[:600]
    if c['description'] and len(c['description']) > 600:
        desc_short += '…'

    body = f"""
    <section class="page-h">
      <a class="backlink" href="/controls">← controls</a>
      <h1 class="h-page mono">{esc(c['control_id'])}</h1>
      <div class="subtitle">{esc(c['title'])}</div>
    </section>

    <section class="panel">
      <h2 class="panel-h">CONTROL METADATA</h2>
      <dl class="kv">
        <dt>Family</dt><dd>{esc(c['family'])}</dd>
        <dt>Baseline (lowest)</dt><dd><span class="bl bl-{esc(c['baseline'] or 'none').lower()}">{esc((c['baseline'] or 'none').upper())}</span></dd>
        <dt>All baselines</dt><dd class="mono">{esc(c['all_baselines'] or 'None')}</dd>
        <dt>Description</dt><dd class="desc">{esc(desc_short)}</dd>
      </dl>
    </section>

    <section class="panel panel-flush">
      <h2 class="panel-h">MAPPED FINDINGS <span class="counter">{len(d['rhsas'])}</span></h2>
      <table class="tbl">
        <thead><tr><th>SEV</th><th>RHSA</th><th>PACKAGE</th><th>CONF</th><th>TITLE</th></tr></thead>
        <tbody>{rows_html}</tbody>
      </table>
    </section>
    """
    return render_layout(c['control_id'], body, 'ctrl'), 200


# ----------------------------------------------------------------------------
# Page: scans
# ----------------------------------------------------------------------------

def page_scans():
    rows = all_scans()
    tbody = []
    for r in rows:
        try:
            fp = json.loads(r['system_fingerprint'])
            host = fp.get('primary_host_name', '—')
        except Exception:
            host = '—'
        tbody.append(f"""
          <tr>
            <td class="mono">{r['scan_id']}</td>
            <td class="mono">{esc(r['scan_date'])}</td>
            <td>{esc(host)}</td>
            <td class="mono">{esc(r['feed_file'])}</td>
            <td class="num">{r['total_definitions']}</td>
            <td class="num">{r['true_count']}</td>
            <td class="num">{r['finding_count']}</td>
            <td class="mono mono-tiny">{esc((r['feed_sha256'] or '')[:16])}…</td>
          </tr>
        """)
    body_html = '\n'.join(tbody) if tbody else '<tr><td colspan="8" class="muted">no scans imported</td></tr>'

    body = f"""
    <section class="page-h">
      <h1 class="h-page">SCAN HISTORY</h1>
      <div class="page-h-meta">{len(rows)} scan(s) on file</div>
    </section>
    <section class="panel panel-flush">
      <table class="tbl">
        <thead><tr>
          <th>ID</th><th>DATE</th><th>HOST</th><th>FEED</th>
          <th class="num">DEFS</th><th class="num">TRUE</th><th class="num">FINDINGS</th>
          <th>SHA-256</th>
        </tr></thead>
        <tbody>{body_html}</tbody>
      </table>
    </section>
    """
    return render_layout('Scans', body, 'scan')


